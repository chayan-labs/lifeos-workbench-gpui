# Life OS environment - copy to .env and `source .env` (or export per shell).
# EVERYTHING here is optional: with zero configuration Life OS runs fully
# local (SQLite file DB, keyless AI through whatever agent CLI is on PATH).

# ── Core (all have working defaults) ────────────────────────────────────────
# LIFEOS_DB_PATH=lifeos.db                 # canonical DB file (libSQL/SQLite)
# LIFEOS_DERIVED_DB_PATH=lifeos-derived.db # un-synced derived store (FTS5/vec)
# LIFEOS_BIND_ADDR=127.0.0.1:8080          # API bind address
# LIFEOS_JWT_SECRET=                       # session signing; random if unset
# LIFEOS_VCS_BLOB_ROOT=lifeos-blobs        # content-addressed blob store root

# ── AI engine (keyless - local agent CLIs are the engine) ──────────────────
# LIFEOS_AGENT=claude              # default agent CLI (claude|gemini|codex|
#                                  # opencode|hermes|antigravity|openclaw);
#                                  # unset = first detected on PATH
# LIFEOS_AGENT_MODEL=              # default model override (e.g. haiku)
# LIFEOS_AGENT_CWD=                # cwd the agent CLI is spawned in
# LIFEOS_AGENT_TIMEOUT_SECS=180
# ANTHROPIC_API_KEY=               # OPTIONAL fallback lane, only consulted
#                                  # when no agent CLI is found on PATH

# ── Always-on cloud sync (optional - Turso/libSQL embedded replica) ────────
# TURSO_URL=libsql://<db>.turso.io
# TURSO_TOKEN=
# LIFEOS_SYNC_INTERVAL_SECS=60
# TURSO_PLATFORM_API_TOKEN=        # db-per-workspace provisioning (SaaS mode)
# TURSO_ORG_SLUG=

# ── Drain (heavy-lane job worker) extras ────────────────────────────────────
# LIFEOS_WHISPER_MODEL=            # path to a GGML whisper model (audio ingest)
# LIFEOS_MEMVEC=                   # path to memvec.py (semantic embedding)
# LIFEOS_TESSERACT_BIN=            # tesseract CLI (OCR lane)
# LIFEOS_MEMORY_SLEEP_THRESHOLD=25 # unconsolidated-importance trigger
# PIPELINE_EVAL_SAMPLE_RATE=0.2
# TELEGRAM_ADMIN_CHAT_ID=

# ── Owned-credential integrations (all optional, docs/INTEGRATIONS.md) ─────
# NANGO_SERVER_URL=                # self-hosted Nango (OAuth vault)
# NANGO_SECRET_KEY_DEV=
# LIFEOS_SECRET_ENCRYPTION_KEY=    # envelope encryption for non-Nango secrets
# KITE_API_KEY=                    # Zerodha Kite (READ-ONLY by design)
# KITE_API_SECRET=
# GOWA_BASE_URL=                   # self-hosted WhatsApp bridge
# GOWA_BASIC_AUTH=
# GOWA_WEBHOOK_SECRET=
# BROWSER_ACTUATOR_SCRIPT=         # gated browser actuator entrypoint
# LIFEOS_MARKETPLACE_SIGNING_SEED= # module marketplace signing key
