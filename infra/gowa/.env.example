# Copy to .env (gitignored) and fill in. See docs/MANUAL-SETUP.md #52 for
# how to generate each value and pair a WhatsApp account.

# Server-wide Basic Auth GOWA requires for every REST call. lifeos-api is
# the only caller (never exposed to agents/users). Format: user:pass.
# Generate the password with: openssl rand -hex 16
GOWA_BASIC_AUTH=lifeos:change-me-generate-a-real-password

# Shared secret for verifying inbound webhook calls. Must match lifeos-api's
# GOWA_WEBHOOK_SECRET exactly (same value, both places).
# Generate with: openssl rand -base64 32
GOWA_WEBHOOK_SECRET=

# Where GOWA sends inbound message webhooks - must be reachable FROM the
# container (a tunnel like ngrok/Cloudflare Tunnel during dev, since this
# points at lifeos-api which is outside this compose network). Leave blank
# to skip inbound message capture entirely (pairing + gated send-drafts
# still work without it).
WHATSAPP_WEBHOOK=

# Local port GOWA's REST API binds to (127.0.0.1 only).
GOWA_PORT=8082
